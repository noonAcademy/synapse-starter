{
  "name": "synapse-starter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Synapse starter template (slice 1) — clone into Replit, paste secrets, hit Run, and one event lands attributed in staging Citadel.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx watch server/index.ts",
    "build": "vite build",
    "start": "tsx server/index.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.client.json",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "vitest run"
  },
  "dependencies": {
    "@noonacademy/synapse-sdk": "^0.1.0",
    "@tailwindcss/vite": "^4.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "express": "^4.21.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.2",
    "vite": "^6.0.7"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@types/express": "^4.17.21",
    "@types/node": "^22.13.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "cross-env": "^7.0.3",
    "typescript": "^5.7.0",
    "vitest": "^2.1.8"
  }
}
