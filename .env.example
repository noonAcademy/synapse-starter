SYNAPSE_BASE_URL=https://citadel.staging.noonedu.io   # staging; config, not a secret
SYNAPSE_APP_ID=
SYNAPSE_APP_SECRET=
GITHUB_TOKEN=                                          # read:packages, for installing the SDK

# --- Sign in with Noon (end-user auth for the DEPLOYED app only) ---
GOOGLE_CLIENT_ID=                                      # Google Identity Services client id; config, not a secret
APP_OAUTH_REDIRECT_URI=https://<deployed>.replit.app/oauth/callback   # must match the URI whitelisted in Citadel; config
APP_SESSION_SECRET=                                    # secret; HMAC-signs the app's own session cookie
